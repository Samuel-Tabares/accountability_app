# Copiar este archivo a:
#   .env.local            — credenciales staging (usadas por `npm run dev`)
#   .env.production.local — credenciales producción (usadas por `npm run dev:prod`)
# Ninguno de los dos archivos se sube a git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_ALIAS_DOMAIN=trabix.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ALLOW_BOOTSTRAP_ADMIN=true
